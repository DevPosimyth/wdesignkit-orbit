{
  "_comment": "Copy this file to qa.config.json and fill in your details. qa.config.json is gitignored — never commit credentials.",

  "product": {
    "name": "WDesignKit",
    "type": "saas-web",
    "version": "1.0.0",
    "team": "WDesignKit QA Expert"
  },

  "properties": {
    "wdesignkit": {
      "name": "WDesignKit Main",
      "url": "https://wdesignkit.com",
      "testAreas": [
        "auth-login",
        "auth-signup",
        "auth-forgot-password",
        "auth-reset-password",
        "dashboard",
        "widget-builder",
        "homepage"
      ]
    },
    "learningCenter": {
      "name": "WDesignKit Learning Center",
      "url": "https://learn.wdesignkit.com",
      "testAreas": [
        "core-pages",
        "navigation",
        "search",
        "seo",
        "security-headers"
      ]
    }
  },

  "environment": {
    "qaEmail": "your-qa-email@example.com",
    "qaPassword": "your-qa-password",
    "stagingUrl": "",
    "runAgainst": "production"
  },

  "competitors": [
    "https://elementor.com",
    "https://wpbakery.com",
    "https://startertemplates.com/"
  ],

  "qaFocus": {
    "priority": "full",
    "testAreas": [
      "auth",
      "dashboard",
      "widget-builder",
      "learning-center",
      "responsive",
      "accessibility",
      "visual-regression"
    ]
  },

  "thresholds": {
    "lighthouse": {
      "performance": 75,
      "accessibility": 85,
      "bestPractices": 80,
      "seo": 80
    },
    "jsBundleKb": 500,
    "cssBundleKb": 200,
    "pageLoadMs": 4000
  },

  "viewports": {
    "mobile": { "width": 375, "height": 812 },
    "tablet": { "width": 768, "height": 1024 },
    "desktop": { "width": 1440, "height": 900 }
  },

  "reporting": {
    "outputDir": "reports",
    "screenshotsDir": "reports/screenshots",
    "snapshotsDir": "tests/snapshots",
    "htmlReport": "reports/playwright-html"
  }
}