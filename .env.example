# WDesignKit Playwright — Plugin Test Environment
# Copy to .env and fill in real values before running plugin tests.

# WordPress local install
PLUGIN_URL=http://localhost:8881
WP_ADMIN_USER=admin
WP_ADMIN_PASS=admin@123

# WDesignKit SaaS auth (required for AI Widget Builder + template import tests)
# Obtain a token from your WDesignKit account API keys page.
WDKIT_API_TOKEN=
WDKIT_EMAIL=
